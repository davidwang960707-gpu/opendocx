# OpenDocX environment template
# Copy this file to .env and adjust values for your local setup.

# Database
DATABASE_URL=postgresql+asyncpg://opendocx:opendocx@localhost:5432/opendocx

# Redis
REDIS_URL=redis://localhost:6379

# Security
SECRET_KEY=opendocx-dev-secret-change-me
JWT_SECRET_KEY=opendocx-jwt-dev-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS origins, comma separated
CORS_ORIGINS=http://localhost:3077,http://localhost:8001

# Embedding
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DEVICE=cpu

# Optional editor AI configuration
# Fill this with an OpenAI-compatible API key when you want AI features.
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT=60
