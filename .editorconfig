# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 100

[*.{py,pyi}]
indent_size = 4
max_line_length = 100

[*.{md,markdown}]
trim_trailing_whitespace = false  # markdown 用尾空格做换行

[*.md]
indent_size = 2
max_line_length = 120

[Makefile]
indent_style = tab
